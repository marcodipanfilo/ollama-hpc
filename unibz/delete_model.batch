#!/bin/bash

#SBATCH --job-name=ollama-del-model
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=2
#SBATCH --mem=8G
#SBATCH --time=00:30:00
#SBATCH --account=vkg_mpboot
#SBATCH --partition=gpu-pre
#SBATCH --output=logs/%j.out
#SBATCH --error=logs/%j.err

export PATH=$HOME/.local/bin:$PATH

export GIN_MODE=release
export OLLAMA_HOST=0.0.0.0
export OLLAMA_MODELS=/data/users/mdipanfilo/ollama

MODEL="${MODEL:-}"

if [ -z "$MODEL" ]; then
    echo "ERROR: MODEL is not set."
    echo "Usage: sbatch --export=ALL,MODEL=qwen2.5:7b delete_model.batch"
    exit 1
fi

echo "==> Starting Ollama server..."
ollama serve >/dev/null 2>&1 &
SERVER_PID=$!

until ollama list >/dev/null 2>&1; do
    echo "Waiting for Ollama server..."
    sleep 2
done

echo "==> Installed models before deletion:"
ollama list

echo "==> Deleting model: $MODEL"
ollama rm "$MODEL"

echo "==> Remaining models:"
ollama list

echo "==> Stopping Ollama server..."
kill "$SERVER_PID"

echo "==> Done."